# 复制为 .env 并填入真实值
# 与主工程（pre-process）使用同一个 ES 实例、MongoDB 实例和索引

# Elasticsearch（阿里云 Serverless ES）
ES_HOSTS=http://jiuyan-search-963.public.cn-shanghai.es-serverless.aliyuncs.com:9200
ES_USERNAME=jiuyan-search-963
ES_PASSWORD=
ES_INDEX=documents
ES_BROWSE_MAX_PAGES=100

# 日志
LOG_LEVEL=INFO


# MongoDB（与主工程共享）
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=knowledgebase
MONGODB_COLLECTION=documents
MONGODB_TASKS_COLLECTION=pipeline_tasks
